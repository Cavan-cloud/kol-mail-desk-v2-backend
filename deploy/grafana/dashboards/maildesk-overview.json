  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Gmail 同步耗时 p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gmail_sync_duration_seconds_bucket[5m])) by (le, mode))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Gmail 同步失败速率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(gmail_sync_failed_total[5m])) by (mode)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "AI 失败率（5m）",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(ai_invocation_total{outcome=\"failure\"}[5m])) / clamp_min(sum(rate(ai_invocation_total[5m])), 1e-9)",
          "legendFormat": "failure rate",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "定时邮件派发滞后（秒）",
      "type": "timeseries",
      "targets": [
        {
          "expr": "scheduled_email_dispatch_lag_seconds{application=\"maildesk-worker\"}",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    }
  ],
