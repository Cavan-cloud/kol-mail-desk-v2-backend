# ============================================================
# kol-mail-desk-v2-backend · 环境变量模板
# ------------------------------------------------------------
# 用法：
#   1. cp .env.example .env
#   2. 按下方注释填入真实值（敏感值不要提交到 git）
#   3. 启动前：set -a; source .env; set +a
#
# 真正的 .env 已在 .gitignore 中，永远不要 commit。
# 字段权威列表见 ../kol-mail-desk-v2-docs/specs/SETUP.md § 4.1
# ============================================================

# ===== 基础 =====
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ===== 数据库（默认匹配 docker-compose.dev.yml）=====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=maildesk
DB_USER=maildesk
DB_PASSWORD=maildesk_local

# ===== Redis（默认匹配 docker-compose.dev.yml）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Google OAuth（P1-T04 起需要）=====
# 申请：https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.send

# ===== 飞书（P2-T01 起需要）=====
# 申请：https://open.feishu.cn/app
# 多维表格（Bitable）示例链接：
#   https://xxx.feishu.cn/base/{FEISHU_KOL_APP_TOKEN}?table={FEISHU_KOL_TABLE_ID}
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Bitable app token（/base/ 后面的 token）
FEISHU_KOL_APP_TOKEN=
# 可选：只同步单个 table；留空则同步全部「N月」+ 欧美/拉美/韩国
FEISHU_KOL_TABLE_ID=
# bitable（默认）| sheet（电子表格按月 tab）
FEISHU_SYNC_SOURCE=bitable
# roster（全部月份+区域）| recent-months（近 N 月）| all（全部 tab）
FEISHU_TAB_FILTER=roster
FEISHU_REGIONAL_TAB_NAMES=欧美,拉美,韩国
# 仅 tab-filter=recent-months 时生效
FEISHU_SHEET_RECENT_MONTHS=2
# true=每次全量同步，不限制 mergedPairs 上限
FEISHU_FULL_SYNC=true

# ===== AI（多供应商：Moonshot/Kimi + DeepSeek，OpenAI 兼容协议，见 ADR-007）=====
AI_DEFAULT_PROVIDER=moonshot
# ---- Moonshot / Kimi ----
MOONSHOT_API_KEY=
# 不要带 /v1 后缀 — Spring AI 会自动拼 /v1/chat/completions
MOONSHOT_BASE_URL=https://api.moonshot.cn
# ---- DeepSeek ----
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Gmail 同步是否调用 LLM 分类（false = 仅按 inbound/outbound 判断待回复）
GMAIL_AI_CLASSIFICATION_ENABLED=false
# 切换默认供应商：改 AI_DEFAULT_PROVIDER 为 deepseek 并填好 DEEPSEEK_API_KEY 即可，不用改代码
# 各能力（classify/draft/check/translate）到具体模型 ID 的映射在 application.yml 的 maildesk.ai.* 配置里

# ===== 加密主密钥（必填，P1-T04 起需要）=====
# 生成：openssl rand -base64 32
# 必须是 base64 编码后的 32 字节
TOKEN_ENCRYPTION_KEY=

# ===== 多租户（开发期固定值，UUID v4）=====
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ===== 前端 CORS（多个用逗号分隔）=====
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ===== 可观测性（P6-T08，可选）=====
# OTEL_TRACING_ENABLED=true
# OTEL_TRACES_SAMPLER_ARG=0.1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ===== Gmail 冒烟（P5-T20，可选，不提交真实 token）=====
# 仅用于：mvn -pl maildesk-integration -Dtest=GmailSendSmokeTest test
# 详见 ../kol-mail-desk-v2-docs/scripts/gmail-send-smoke.md
GMAIL_SMOKE_ACCESS_TOKEN=
GMAIL_SMOKE_TO=
GMAIL_SMOKE_CC=
